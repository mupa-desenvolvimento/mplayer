<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/enterprise_bg">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageView
        android:id="@+id/hiddenDevTapArea"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="top|start"
        android:alpha="0.01"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/ic_mupa_logo" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/unlockFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:alpha="0"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/ic_mupa_logo"
        app:backgroundTint="@color/enterprise_surface"
        app:fabSize="mini"
        app:tint="@color/mupa_cyan" />

    <ImageView
        android:id="@+id/unlockHotspot"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="top|end"
        android:alpha="0.01"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/ic_mupa_logo" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/offlineOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@color/enterprise_bg"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/offlineCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardBackgroundColor="@color/enterprise_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/mupa_cyan"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="520dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/offlineLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_mupa_logo"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/offlineTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/reconnecting"
                    android:textColor="@color/enterprise_on"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toStartOf="@id/offlineProgress"
                    app:layout_constraintStart_toEndOf="@id/offlineLogo"
                    app:layout_constraintTop_toTopOf="@id/offlineLogo" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/offlineProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:indicatorColor="@color/mupa_cyan"
                    app:layout_constraintBottom_toBottomOf="@id/offlineLogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/offlineLogo" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/devOverlayCard"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:alpha="0.92"
        android:visibility="gone"
        app:cardBackgroundColor="@color/enterprise_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/mupa_cyan"
        app:strokeWidth="1dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/devOverlayText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textColor="@color/enterprise_on"
            android:textSize="12sp" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/deviceIdWatermark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:alpha="0.38"
        android:textColor="@color/enterprise_on_muted"
        android:textSize="11sp" />

</FrameLayout>
